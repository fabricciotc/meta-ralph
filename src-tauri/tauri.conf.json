{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgenticFlow",
  "version": "0.5.0",
  "identifier": "com.agenticflow.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:5051",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": {
        "default-src": "'self' http://127.0.0.1:5051",
        "script-src": "'self' 'unsafe-inline' http://127.0.0.1:5051",
        "style-src": "'self' 'unsafe-inline' http://127.0.0.1:5051 https://fonts.googleapis.com",
        "connect-src": "'self' http://127.0.0.1:5051 ws://127.0.0.1:5051",
        "img-src": "'self' data: blob: http://127.0.0.1:5051",
        "font-src": "'self' https://fonts.gstatic.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis", "deb", "appimage"],
    "externalBin": ["binaries/dashboard-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
