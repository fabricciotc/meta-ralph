{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgenticFlow",
  "version": "0.5.0",
  "identifier": "com.agenticflow.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:5051",
    "frontendDist": "../dashboard/static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": {
        "default-src": "*",
        "script-src": "* 'unsafe-inline' 'unsafe-eval'",
        "style-src": "* 'unsafe-inline'",
        "connect-src": "*",
        "img-src": "* data: blob:",
        "font-src": "*"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis", "deb", "appimage"],
    "externalBin": ["binaries/dashboard-server"],
    "macOS": {
      "exceptionDomain": "127.0.0.1"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
